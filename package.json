{
  "name": "geoweb3-dapp-production-ready",
  "version": "1.1.0",
  "description": "GeoWeb3 DApp with production backend for Esri OAuth, OTP, IPFS, Polygon rewards, and DAO workflows",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/start-frontend.mjs",
    "dev:lan": "set VITE_HOST=0.0.0.0&& node scripts/start-frontend.mjs",
    "build": "vite build",
    "preview": "node scripts/preview-frontend.mjs",
    "backend": "node backend/server.js",
    "dev:full": "concurrently \"npm run backend\" \"npm run dev\"",
    "deploy:contracts": "hardhat run scripts/deploy.js --network polygonAmoy",
    "compile:contracts": "hardhat compile",
    "compile:contracts:local": "solcjs --base-path . --include-path node_modules --bin --abi contracts/GeoWeb3.sol -o artifacts-solc",
    "serve:dist": "node scripts/serve-dist.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.2.1",
    "axios": "1.7.9",
    "concurrently": "9.1.2",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "ethers": "6.13.5",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "nodemailer": "6.9.16",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.1",
    "vite": "5.4.21",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "3.0.8",
    "@openzeppelin/contracts": "5.2.0",
    "hardhat": "2.22.17",
    "solc": "^0.8.20"
  }
}
