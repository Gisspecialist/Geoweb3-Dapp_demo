# ─────────────────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_POLYGON_CHAIN_ID=80002
VITE_GEOW_TOKEN_ADDRESS=
VITE_SERVICE_NFT_ADDRESS=
VITE_REWARDS_ADDRESS=
VITE_GEOW_DAO_ADDRESS=
VITE_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ─────────────────────────────────────────────────────────────
# Backend server
# ─────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_ORIGIN=http://127.0.0.1:3000
OTP_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
DAO_QUORUM=5

# ArcGIS OAuth app credentials
ESRI_CLIENT_ID=YOUR_ESRI_CLIENT_ID
ESRI_CLIENT_SECRET=YOUR_ESRI_CLIENT_SECRET

# SMTP email delivery for OTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@geoweb3.app

# IPFS / Pinata — backend only, never expose this in the browser
PINATA_JWT=YOUR_PINATA_JWT

# Polygon / Hardhat / Oracle
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
ORACLE_PRIVATE_KEY=0xYOUR_ORACLE_PRIVATE_KEY
ORACLE_ADDRESS=0xYOUR_ORACLE_WALLET_ADDRESS
REWARDS_ENGINE_ADDRESS=0xDEPLOYED_REWARDS_ENGINE

# OpenStreetMap reward validation
OSM_USER_AGENT=GeoWeb3-DApp/1.0 (contact@example.com)
OSM_OAUTH_CLIENT_ID=
OSM_OAUTH_CLIENT_SECRET=
